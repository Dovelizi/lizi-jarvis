# =====================================================================
# lizi-jarvis · 统一密钥与配置文件范本
# ---------------------------------------------------------------------
# 用法：复制本文件为 .env（位于项目根目录），按下方备注逐项填写
# 命令：cp .env.example .env
#
# 字段格式：每个变量上方有 4 行注释
#   1) 用途：这个变量做什么
#   2) 来源：在哪里获取
#   3) 必填：P0 必填 / P1 选填 / 缺失行为
#   4) 默认值：留空时 lizi-jarvis 的兜底逻辑
#
# 安全提醒：所有密钥字段当前留空。请填入你自己的密钥后再启动服务。
#          .env 已加入 .gitignore，永远不会被推送到远端。
# =====================================================================


# ---------------------------------------------------------------------
# [服务] 本地服务监听
# ---------------------------------------------------------------------

# 用途：HTTP/WS 服务监听端口
# 来源：自定义（避开系统已占用端口）
# 必填：否
# 默认值：5173
PORT=5173

# 用途：监听地址。本地单用户安全建议 127.0.0.1，禁止 0.0.0.0 暴露公网
# 来源：自定义
# 必填：否
# 默认值：127.0.0.1
HOST=127.0.0.1

# 用途：日志级别 fatal/error/warn/info/debug/trace
# 来源：自定义
# 必填：否
# 默认值：info
LOG_LEVEL=info

# 用途：调度器时区，影响 07:00 早间播报等节律时间
# 来源：IANA 时区名
# 必填：否
# 默认值：Asia/Shanghai
TZ=Asia/Shanghai


# ---------------------------------------------------------------------
# [Brain] Claude Code CLI 大脑
# ---------------------------------------------------------------------

# 用途：本机 Claude CLI 命令名。lizi-jarvis 会以子进程方式调用
#       约定输入走 stdin、输出走 stdout JSON
# 来源：本机已安装的 CLI 命令名（例如：claude / claude-router）
#       如果你用的是 claude-code-router 之类的代理，改成对应命令名即可
# 必填：是
# 默认值：claude
BRAIN_CLI_CMD=claude

# 用途：传给 CLI 的固定参数。-p 表示 prompt 模式，--output-format json 要求结构化输出
# 来源：参考 Anthropic 官方 claude-code 文档
# 必填：否
# 默认值：-p --output-format json
BRAIN_CLI_ARGS=-p --output-format json

# 用途：Brain 调用超时时间（毫秒）。超时后 lizi-jarvis 返回兜底 say
# 来源：自定义
# 必填：否
# 默认值：30000
BRAIN_TIMEOUT_MS=30000


# ---------------------------------------------------------------------
# [音乐] QQ 音乐源（本期主用） + Mock 兜底
# ---------------------------------------------------------------------

# 用途：选择音乐源 provider：qq / mock
#       未配置 QQ_MUSIC_COOKIE 时即使设置 qq 也会自动 fallback 到 mock
# 来源：自定义
# 必填：否
# 默认值：qq
MUSIC_PROVIDER=qq

# 用途：QQ 音乐 Cookie 字符串。lizi-jarvis 用它调搜索/直链/歌词接口
# 来源：① 浏览器登录 https://y.qq.com
#       ② F12 → Network → 任意请求 → Request Headers → Cookie
#       ③ 整段复制粘贴到此处（注意：包含等号、分号、空格的完整字符串）
#       ④ 推荐用单引号包裹避免 shell 转义： QQ_MUSIC_COOKIE='pgv_pvid=...; uin=...; ...'
# 必填：否（缺失时自动用 MockProvider，仍可启动）
# 默认值：空
QQ_MUSIC_COOKIE=


# ---------------------------------------------------------------------
# [天气] QWeather 和风天气
# ---------------------------------------------------------------------

# 用途：QWeather API Key，用于 lizi-jarvis 主动播报中引用天气
# 来源：① 注册 https://dev.qweather.com
#       ② 控制台 → 应用管理 → 创建项目 → 创建 KEY
#       ③ 选 Web API，复制 KEY
# 必填：是（天气片段依赖）
# 默认值：缺失则环境注入跳过天气片段，Brain 仍可工作
QWEATHER_KEY=

# 用途：默认查询的城市 LocationID
# 来源：https://geoapi.qweather.com/v2/city/lookup?location=城市名&key=YOUR_KEY
#       例：北京=101010100，上海=101020100，广州=101280101，深圳=101280601
# 必填：是
# 默认值：101010100（北京）
QWEATHER_LOCATION=101010100

# 用途：QWeather API Host（2024 后新创建的 KEY 必填，否则 403 Invalid Host）
# 来源：QWeather 控制台 → 项目管理 → 你的 KEY 详情页 → "API Host"
#       格式形如：xxxxxxxx.re.qweatherapi.com（每个账号不同）
#       老 KEY 可保留默认 devapi.qweather.com
# 必填：新 KEY 必填
# 默认值：devapi.qweather.com
QWEATHER_HOST=devapi.qweather.com


# ---------------------------------------------------------------------
# [TTS] 语音合成
#   - edge-tts:    Microsoft Edge 在线（免费、无需 key、机械感较重）
#   - siliconflow: SiliconFlow CosyVoice2-0.5B（自然真人感，需 SILICONFLOW_KEY）
#                  失败自动回退 edge-tts
# ---------------------------------------------------------------------

# 用途：TTS 引擎选择
# 来源：自定义
# 必填：否
# 默认值：webspeech（兼容老配置，行为同 edge-tts）
TTS_PROVIDER=siliconflow

# 用途：SiliconFlow API Key（仅当 TTS_PROVIDER=siliconflow 时使用）
# 来源：① 注册 https://cloud.siliconflow.cn （微信扫码即可）
#       ② 控制台 → API 密钥 → 新建
#       ③ 新用户送 ¥14 代金券，约可用 44 万中文字符
# 必填：当 TTS_PROVIDER=siliconflow 时必填
# 默认值：空（缺失时自动回退 edge-tts）
SILICONFLOW_KEY=

# 用途：SiliconFlow TTS 模型（当前唯一推荐：CosyVoice2-0.5B）
# 来源：https://cloud.siliconflow.cn/models?types=speech
# 必填：否
# 默认值：FunAudioLLM/CosyVoice2-0.5B
SILICONFLOW_MODEL=FunAudioLLM/CosyVoice2-0.5B

# 用途：SiliconFlow 默认音色（8 个预置可选）
#       男声：alex/benjamin/charles/david
#       女声：anna/bella/claire/diana
# 来源：自定义
# 必填：否
# 默认值：claire（温柔女声）
SILICONFLOW_VOICE=claire

# 用途：Fish Audio API Key（已弃用，留作未来扩展）
# 来源：https://fish.audio
# 必填：否
# 默认值：空
FISH_AUDIO_KEY=


# ---------------------------------------------------------------------
# [飞书] 日历注入（P1，第二期启用）
# ---------------------------------------------------------------------

# 用途：飞书自建应用 ID，用于读取你的日历作为 lizi-jarvis 上下文
# 来源：① 飞书开放平台 https://open.feishu.cn → 创建企业自建应用
#       ② 凭证与基础信息 → App ID
# 必填：否（P1）
# 默认值：空
FEISHU_APP_ID=

# 用途：飞书自建应用 Secret
# 来源：同上 → App Secret
# 必填：否（P1）
# 默认值：空
FEISHU_APP_SECRET=


# ---------------------------------------------------------------------
# [开发选项]
# ---------------------------------------------------------------------

# 用途：是否在启动时打印一次 .env 加载摘要（脱敏，仅打印 key 名是否非空）
# 来源：自定义
# 必填：否
# 默认值：true
PRINT_CONFIG_SUMMARY=true
