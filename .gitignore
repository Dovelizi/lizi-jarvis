# =====================================================================
# lizi-jarvis · .gitignore
# 安全铁律：所有可能含密钥/账号/cookie 的文件必须忽略
# =====================================================================

# --- 密钥 / 环境变量 ---
.env
.env.local
.env.*.local
.env.example.local

# --- 依赖 ---
node_modules/
pwa/node_modules/
server/node_modules/

# --- 运行时数据 / 缓存 ---
server/data/state.db
server/data/state.db-*
server/data/tts/
server/data/mock/

# --- 构建产物 ---
pwa/dist/
pwa/dev-dist/
*.log
*.pid

# --- 个人语料（含个人化品味、可能 PII） ---
user/

# --- 系统垃圾 ---
.DS_Store
Thumbs.db

# --- IDE / 编辑器 ---
.vscode/
.idea/
*.swp
*~

# --- Codebuddy 本地状态 ---
.codebuddy/
